<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GymGenie AI</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:linear-gradient(135deg,#0f172a,#111827);
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:20px;
color:white;
}

.container{
width:100%;
max-width:900px;
background:#1e293b;
padding:35px;
border-radius:25px;
box-shadow:0 20px 40px rgba(0,0,0,.4);
}

h1{
text-align:center;
font-size:50px;
margin-bottom:10px;
color:#22c55e;
}

.subtitle{
text-align:center;
color:#cbd5e1;
margin-bottom:30px;
}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
}

.card{
background:#0f172a;
padding:25px;
border-radius:20px;
}

label{
display:block;
margin-bottom:8px;
margin-top:15px;
}

select{
width:100%;
padding:14px;
border:none;
border-radius:10px;
font-size:15px;
}

button{
width:100%;
margin-top:20px;
padding:15px;
border:none;
border-radius:12px;
background:#22c55e;
color:white;
font-size:16px;
cursor:pointer;
}

button:hover{
background:#16a34a;
}

.result{
display:none;
line-height:1.9;
}

.plan{
background:#1e293b;
padding:15px;
margin-top:15px;
border-radius:12px;
}

.badge{
display:inline-block;
padding:8px 15px;
background:#22c55e;
border-radius:20px;
margin-bottom:15px;
}

@media(max-width:768px){

.grid{
grid-template-columns:1fr;
}

h1{
font-size:38px;
}

}

</style>
</head>
<body>

<div class="container">

<h1>🏋️ GymGenie AI</h1>

<p class="subtitle">
Generate personalized gym plans instantly.
</p>

<div class="grid">

<div class="card">

<label>Fitness Goal</label>

<select id="goal">
<option>Muscle Gain</option>
<option>Weight Loss</option>
<option>Strength Building</option>
<option>General Fitness</option>
</select>

<label>Experience Level</label>

<select id="level">
<option>Beginner</option>
<option>Intermediate</option>
<option>Advanced</option>
</select>

<label>Workout Days / Week</label>

<select id="days">
<option>3</option>
<option>4</option>
<option>5</option>
<option>6</option>
</select>

<button onclick="generatePlan()">
Generate Plan
</button>

</div>

<div class="card">

<div id="result" class="result">

<div class="badge">
Custom Plan Generated
</div>

<div id="planOutput"></div>

</div>

</div>

</div>

</div>

<script>

function generatePlan(){

const goal =
document.getElementById("goal").value;

const level =
document.getElementById("level").value;

const days =
document.getElementById("days").value;

document.getElementById("result").style.display="block";

let workout = "";

if(goal==="Muscle Gain"){

workout = `
<div class="plan">
Monday - Chest & Triceps
</div>

<div class="plan">
Tuesday - Back & Biceps
</div>

<div class="plan">
Wednesday - Rest
</div>

<div class="plan">
Thursday - Legs
</div>

<div class="plan">
Friday - Shoulders
</div>
`;
}

else if(goal==="Weight Loss"){

workout = `
<div class="plan">
HIIT Cardio - 30 Minutes
</div>

<div class="plan">
Full Body Circuit Training
</div>

<div class="plan">
Core Workout
</div>

<div class="plan">
Running / Cycling
</div>
`;
}

else if(goal==="Strength Building"){

workout = `
<div class="plan">
Squats 5x5
</div>

<div class="plan">
Deadlifts 5x5
</div>

<div class="plan">
Bench Press 5x5
</div>

<div class="plan">
Overhead Press 5x5
</div>
`;
}

else{

workout = `
<div class="plan">
Full Body Workout
</div>

<div class="plan">
Mobility Training
</div>

<div class="plan">
Light Cardio
</div>

<div class="plan">
Stretching Session
</div>
`;
}

document.getElementById("planOutput").innerHTML =

`
<h3>Goal: ${goal}</h3>
<br>
<p>Level: ${level}</p>
<p>Days per Week: ${days}</p>
<br>
${workout}
`;

}

</script>

</body>
</html>
