<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dev Portfolio</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Segoe UI', sans-serif;
}

body {
  background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
  color: white;
}

/* NAVBAR */
nav {
  display: flex;
  justify-content: space-between;
  padding: 20px 50px;
  backdrop-filter: blur(10px);
}

nav h1 {
  font-size: 24px;
}

nav a {
  color: white;
  margin-left: 20px;
  text-decoration: none;
}

/* HERO */
.hero {
  height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  flex-direction: column;
}

.hero h2 {
  font-size: 50px;
  animation: fadeIn 2s ease-in-out;
}

.hero p {
  margin-top: 15px;
  font-size: 18px;
  opacity: 0.8;
}

.btn {
  margin-top: 20px;
  padding: 12px 25px;
  border: none;
  background: #00c6ff;
  color: black;
  border-radius: 25px;
  cursor: pointer;
  transition: 0.3s;
}

.btn:hover {
  background: #0072ff;
  color: white;
}

/* CARDS */
.projects {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  padding: 50px;
  gap: 20px;
}

.card {
  background: rgba(255,255,255,0.1);
  padding: 20px;
  border-radius: 15px;
  backdrop-filter: blur(15px);
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-10px) scale(1.03);
}

/* FOOTER */
footer {
  text-align: center;
  padding: 20px;
  opacity: 0.6;
}

/* ANIMATION */
@keyframes fadeIn {
  from {opacity: 0; transform: translateY(20px);}
  to {opacity: 1; transform: translateY(0);}
}
</style>
</head>

<body>

<nav>
  <h1>MyDev</h1>
  <div>
    <a href="#">Home</a>
    <a href="#">Projects</a>
    <a href="#">Contact</a>
  </div>
</nav>

<section class="hero">
  <h2>Hi, I'm a Web Developer 🚀</h2>
  <p>I build modern web apps with clean UI & powerful backend</p>
  <button class="btn">View Work</button>
</section>

<section class="projects">
  <div class="card">
    <h3>Project One</h3>
    <p>AI-powered app with real-time features.</p>
  </div>
  <div class="card">
    <h3>Project Two</h3>
    <p>Full stack MERN dashboard system.</p>
  </div>
  <div class="card">
    <h3>Project Three</h3>
    <p>Custom code editor in browser.</p>
  </div>
</section>

<footer>
  © 2026 | Built by You 💻
</footer>

</body>
</html>
