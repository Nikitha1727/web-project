<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>InsightFlow Dashboard</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI,sans-serif;
}

body{
background:#f4f7fb;
display:flex;
height:100vh;
overflow:hidden;
}

/* SIDEBAR */

.sidebar{
width:250px;
background:#111827;
color:white;
padding:25px;
}

.logo{
font-size:28px;
font-weight:bold;
margin-bottom:40px;
}

.menu{
display:flex;
flex-direction:column;
gap:15px;
}

.menu a{
text-decoration:none;
color:#cbd5e1;
padding:12px;
border-radius:10px;
transition:.3s;
}

.menu a:hover{
background:#1f2937;
color:white;
}

/* MAIN */

.main{
flex:1;
padding:30px;
overflow:auto;
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
}

.header h1{
color:#111827;
}

.profile{
background:#2563eb;
color:white;
padding:10px 18px;
border-radius:30px;
}

/* CARDS */

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:30px;
}

.card{
background:white;
padding:25px;
border-radius:20px;
box-shadow:0 5px 20px rgba(0,0,0,.05);
}

.card h3{
color:#64748b;
margin-bottom:10px;
}

.card p{
font-size:32px;
font-weight:bold;
color:#111827;
}

/* GRID */

.grid{
display:grid;
grid-template-columns:2fr 1fr;
gap:20px;
}

.panel{
background:white;
padding:25px;
border-radius:20px;
box-shadow:0 5px 20px rgba(0,0,0,.05);
}

.panel h2{
margin-bottom:20px;
color:#111827;
}

/* TASKS */

.task{
display:flex;
justify-content:space-between;
padding:15px;
background:#f8fafc;
margin-bottom:12px;
border-radius:12px;
}

.completed{
color:green;
font-weight:bold;
}

.pending{
color:orange;
font-weight:bold;
}

/* AI BOX */

textarea{
width:100%;
height:150px;
padding:15px;
border:1px solid #ddd;
border-radius:10px;
resize:none;
margin-bottom:15px;
}

button{
padding:12px 20px;
border:none;
background:#2563eb;
color:white;
border-radius:10px;
cursor:pointer;
}

button:hover{
background:#1d4ed8;
}

.result{
margin-top:20px;
padding:15px;
background:#eff6ff;
border-radius:10px;
line-height:1.7;
}

/* MOBILE */

@media(max-width:900px){

.grid{
grid-template-columns:1fr;
}

.sidebar{
display:none;
}

}

</style>
</head>
<body>

<div class="sidebar">

<div class="logo">InsightFlow</div>

<div class="menu">
<a href="#">Dashboard</a>
<a href="#">Meetings</a>
<a href="#">Projects</a>
<a href="#">Tasks</a>
<a href="#">Analytics</a>
<a href="#">Settings</a>
</div>

</div>

<div class="main">

<div class="header">
<h1>Team Productivity Dashboard</h1>
<div class="profile">Nikitha</div>
</div>

<div class="cards">

<div class="card">
<h3>Total Meetings</h3>
<p>48</p>
</div>

<div class="card">
<h3>Tasks Pending</h3>
<p>12</p>
</div>

<div class="card">
<h3>Projects Active</h3>
<p>7</p>
</div>

<div class="card">
<h3>Efficiency Score</h3>
<p>92%</p>
</div>

</div>

<div class="grid">

<div class="panel">

<h2>AI Meeting Analyzer</h2>

<textarea id="meetingText"
placeholder="Paste meeting notes here..."></textarea>

<button onclick="analyzeMeeting()">
Generate Summary
</button>

<div class="result" id="result">

Meeting summary will appear here...

</div>

</div>

<div class="panel">

<h2>Tasks</h2>

<div class="task">
<span>Update Dashboard UI</span>
<span class="completed">Done</span>
</div>

<div class="task">
<span>Deploy Backend API</span>
<span class="pending">Pending</span>
</div>

<div class="task">
<span>Fix Login Bug</span>
<span class="completed">Done</span>
</div>

<div class="task">
<span>Prepare Sprint Report</span>
<span class="pending">Pending</span>
</div>

</div>

</div>

</div>

<script>

function analyzeMeeting(){

const text =
document.getElementById("meetingText").value;

if(text.trim()===""){

alert("Paste meeting notes first");
return;

}

document.getElementById("result").innerHTML =

`
<b>Meeting Summary</b><br><br>

• Team discussed project progress.<br>
• New feature implementation approved.<br>
• Backend deployment scheduled.<br>
• UI improvements assigned.<br><br>

<b>Action Items</b><br>

✓ Complete dashboard redesign<br>
✓ Fix authentication issues<br>
✓ Deploy production build<br><br>

<b>Priority:</b> High
`;

}

</script>

</body>
</html>
