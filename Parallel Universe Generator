<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Parallel Universe Generator</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    min-height:100vh;
    overflow-x:hidden;
    background:linear-gradient(135deg,#020617,#0f172a,#1e1b4b);
    color:white;
    position:relative;
}

/* STARS */

.stars{
    position:fixed;
    width:100%;
    height:100%;
    z-index:-1;
}

.star{
    position:absolute;
    width:3px;
    height:3px;
    background:white;
    border-radius:50%;
    animation:twinkle 3s infinite alternate;
}

@keyframes twinkle{
    from{opacity:.2;}
    to{opacity:1;}
}

/* HEADER */

header{
    text-align:center;
    padding:60px 20px 20px;
}

header h1{
    font-size:4rem;
    background:linear-gradient(to right,#60a5fa,#c084fc,#f472b6);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

header p{
    margin-top:15px;
    color:#cbd5e1;
    font-size:1.1rem;
}

/* INPUT */

.generator{
    max-width:700px;
    margin:40px auto;
    text-align:center;
}

input{
    width:70%;
    padding:16px;
    border:none;
    outline:none;
    border-radius:15px;
    background:rgba(255,255,255,.1);
    color:white;
    font-size:1rem;
    backdrop-filter:blur(10px);
}

button{
    padding:16px 25px;
    border:none;
    border-radius:15px;
    cursor:pointer;
    background:linear-gradient(45deg,#8b5cf6,#3b82f6);
    color:white;
    font-weight:bold;
    margin-left:10px;
    transition:.3s;
}

button:hover{
    transform:translateY(-3px);
}

/* UNIVERSES */

.container{
    width:90%;
    margin:40px auto;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.card{
    background:rgba(255,255,255,.08);
    backdrop-filter:blur(15px);
    border-radius:25px;
    padding:25px;
    border:1px solid rgba(255,255,255,.1);
    transition:.4s;
}

.card:hover{
    transform:translateY(-10px);
}

.card h2{
    color:#c084fc;
    margin-bottom:15px;
}

.card p{
    line-height:1.8;
    color:#e2e8f0;
}

/* TIMELINE */

.timeline{
    margin-top:20px;
}

.timeline div{
    margin:10px 0;
    padding-left:15px;
    border-left:3px solid #60a5fa;
    color:#cbd5e1;
}

/* FOOTER */

footer{
    text-align:center;
    padding:40px;
    color:#94a3b8;
}

</style>
</head>
<body>

<!-- STARS -->

<div class="stars" id="stars"></div>

<header>
    <h1>Parallel Universe Generator</h1>
    <p>
        Explore alternate versions of your future across infinite realities.
    </p>
</header>

<div class="generator">
    <input
        type="text"
        id="nameInput"
        placeholder="Enter your name..."
    >
    <button onclick="generateUniverses()">
        Generate Universes
    </button>
</div>

<div class="container" id="universeContainer">

    <!-- Cards Generated Here -->

</div>

<footer>
    ∞ Every choice creates a new universe.
</footer>

<script>

/* STAR FIELD */

const stars = document.getElementById("stars");

for(let i=0;i<150;i++){

    const star = document.createElement("div");

    star.classList.add("star");

    star.style.left=Math.random()*100+"%";
    star.style.top=Math.random()*100+"%";

    star.style.animationDuration=
        (Math.random()*4+2)+"s";

    stars.appendChild(star);
}

/* UNIVERSE DATA */

const futures=[

"became a billionaire startup founder and launched a revolutionary AI company.",

"traveled to 80 countries documenting adventures for millions of followers.",

"became a world-renowned software engineer building products used by millions.",

"created an education platform that transformed learning globally.",

"became an AI researcher making breakthroughs in healthcare.",

"started a nonprofit helping students learn technology for free.",

"built a gaming studio and released a hit game worldwide.",

"founded a space-tech company helping humanity explore Mars."

];

function generateUniverses(){

    const name =
    document.getElementById("nameInput").value
    || "You";

    const container =
    document.getElementById("universeContainer");

    container.innerHTML="";

    for(let i=1;i<=4;i++){

        const future =
        futures[Math.floor(Math.random()*futures.length)];

        const card =
        document.createElement("div");

        card.classList.add("card");

        card.innerHTML=`

        <h2>🌌 Universe #${Math.floor(Math.random()*999)}</h2>

        <p>
        In this reality,
        <strong>${name}</strong>
        ${future}
        </p>

        <div class="timeline">

            <div>📍 Age 18 → Began learning new skills</div>

            <div>🚀 Age 25 → Major breakthrough</div>

            <div>🏆 Age 35 → Achieved dream goal</div>

            <div>🌟 Age 50 → Left a lasting legacy</div>

        </div>

        `;

        container.appendChild(card);
    }
}

generateUniverses();

</script>

</body>
</html>
