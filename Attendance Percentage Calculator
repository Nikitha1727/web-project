<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Attendance Tracker Pro</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{

background:linear-gradient(135deg,#2563eb,#06b6d4);
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
padding:20px;
transition:.4s;

}

.dark{

background:#111827;

}

.container{

background:white;
width:420px;
padding:25px;
border-radius:20px;
box-shadow:0 10px 25px rgba(0,0,0,.25);
transition:.4s;

}

.dark .container{

background:#1f2937;
color:white;

}

h1{

text-align:center;
color:#2563eb;
margin-bottom:10px;

}

.dark h1{

color:#38bdf8;

}

.subtitle{

text-align:center;
color:gray;
margin-bottom:20px;

}

.dark .subtitle{

color:#d1d5db;

}

input{

width:100%;
padding:12px;
margin:10px 0;
border-radius:8px;
border:1px solid #ccc;
font-size:15px;

}

button{

width:100%;
padding:12px;
margin-top:10px;
border:none;
border-radius:8px;
cursor:pointer;
font-size:16px;
color:white;

}

.calculate{

background:#2563eb;

}

.reset{

background:#ef4444;

}

.darkBtn{

background:#111827;

}

.progress{

width:100%;
height:20px;
background:#ddd;
border-radius:20px;
overflow:hidden;
margin-top:20px;

}

.fill{

height:100%;
width:0%;
background:#22c55e;
transition:.5s;

}

.result{

display:none;
margin-top:20px;
padding:15px;
border-radius:10px;
background:#eef4ff;

}

.dark .result{

background:#374151;

}

.percent{

font-size:45px;
font-weight:bold;
margin:10px 0;

}

.status{

font-size:22px;
font-weight:bold;

}

.info{

margin-top:15px;
line-height:1.8;

}

.footer{

margin-top:20px;
text-align:center;
font-size:13px;
color:gray;

}

.dark .footer{

color:#d1d5db;

}

</style>

</head>

<body>

<div class="container">

<h1>📚 Attendance Tracker Pro</h1>

<p class="subtitle">
Track your attendance smarter.
</p>

<input
type="number"
id="attended"
placeholder="Classes Attended">

<input
type="number"
id="total"
placeholder="Total Classes">

<button
class="calculate"
onclick="calculateAttendance()">

Calculate

</button>

<button
class="reset"
onclick="resetData()">

Reset

</button>

<button
class="darkBtn"
onclick="toggleMode()">

🌙 Dark Mode

</button>

<div class="progress">

<div
class="fill"
id="fill">
</div>

</div>

<div
class="result"
id="result">

<h2>Your Attendance</h2>

<div
class="percent"
id="percent">

0%

</div>

<div
class="status"
id="status">

-

</div>

<div
class="info">

<p id="needed"></p>

<p id="miss"></p>

</div>

</div>

<div class="footer">

Attendance Tracker Pro • HTML • CSS • JavaScript

</div>

<script>
let target = 75;

function calculateAttendance(){

let attended =
Number(document.getElementById("attended").value);

let total =
Number(document.getElementById("total").value);

if(attended<=0 || total<=0){

alert("Enter valid values.");

return;

}

if(attended>total){

alert("Attended classes cannot exceed total classes.");

return;

}

let percentage =
(attended/total)*100;

document.getElementById("result").style.display="block";

document.getElementById("percent").innerHTML=
percentage.toFixed(2)+"%";

document.getElementById("fill").style.width=
percentage+"%";

let status=
document.getElementById("status");

if(percentage>=90){

status.innerHTML="🌟 Excellent Attendance";
status.style.color="green";

}
else if(percentage>=75){

status.innerHTML="✅ Safe Attendance";
status.style.color="orange";

}
else{

status.innerHTML="⚠ Attendance Shortage";
status.style.color="red";

}

let need=0;

if(percentage<75){

while(((attended+need)/(total+need))*100<75){

need++;

}

document.getElementById("needed").innerHTML=
"📚 Attend <b>"+need+
"</b> more consecutive classes to reach 75%.";

document.getElementById("miss").innerHTML="";

}
else{

let miss=0;

while((attended/(total+miss+1))*100>=75){

miss++;

}

document.getElementById("needed").innerHTML=
"🎉 You already satisfy the attendance requirement.";

document.getElementById("miss").innerHTML=
"😎 You can miss <b>"+miss+
"</b> more classes.";

}

localStorage.setItem("attended",attended);
localStorage.setItem("total",total);

}

function resetData(){

document.getElementById("attended").value="";
document.getElementById("total").value="";

document.getElementById("fill").style.width="0%";

document.getElementById("result").style.display="none";

localStorage.clear();

}

function toggleMode(){

document.body.classList.toggle("dark");

}

window.onload=function(){

let a=
localStorage.getItem("attended");

let t=
localStorage.getItem("total");

if(a && t){

document.getElementById("attended").value=a;

document.getElementById("total").value=t;

calculateAttendance();

}

}

</script>

</body>
</html>
