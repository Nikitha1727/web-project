<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgentOps Dashboard</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Inter,sans-serif;
}

body{
background:#0f172a;
color:white;
display:flex;
min-height:100vh;
}

/* SIDEBAR */

.sidebar{
width:260px;
background:#111827;
padding:25px;
}

.logo{
font-size:28px;
font-weight:bold;
margin-bottom:40px;
color:#38bdf8;
}

.menu{
display:flex;
flex-direction:column;
gap:15px;
}

.menu a{
text-decoration:none;
color:#cbd5e1;
padding:12px;
border-radius:10px;
transition:.3s;
}

.menu a:hover{
background:#1e293b;
}

/* MAIN */

.main{
flex:1;
padding:30px;
overflow:auto;
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
}

.header h1{
font-size:36px;
}

.status{
background:#16a34a;
padding:10px 18px;
border-radius:30px;
}

/* CARDS */

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:30px;
}

.card{
background:#1e293b;
padding:25px;
border-radius:20px;
}

.card h3{
color:#94a3b8;
margin-bottom:10px;
}

.card p{
font-size:34px;
font-weight:bold;
}

/* AGENTS */

.section{
background:#1e293b;
padding:25px;
border-radius:20px;
margin-bottom:25px;
}

.section h2{
margin-bottom:20px;
}

.agent{
display:flex;
justify-content:space-between;
align-items:center;
padding:15px;
background:#0f172a;
border-radius:12px;
margin-bottom:10px;
}

.running{
color:#22c55e;
font-weight:bold;
}

.warning{
color:#f59e0b;
font-weight:bold;
}

.error{
color:#ef4444;
font-weight:bold;
}

/* AI INPUT */

textarea{
width:100%;
height:140px;
padding:15px;
border:none;
border-radius:10px;
margin-bottom:15px;
background:#0f172a;
color:white;
resize:none;
}

button{
padding:14px 25px;
border:none;
border-radius:10px;
background:#2563eb;
color:white;
cursor:pointer;
}

.result{
margin-top:20px;
padding:15px;
background:#0f172a;
border-radius:12px;
display:none;
line-height:1.8;
}

/* MOBILE */

@media(max-width:768px){

.sidebar{
display:none;
}

.header h1{
font-size:28px;
}

}

</style>
</head>
<body>

<div class="sidebar">

<div class="logo">
AgentOps
</div>

<div class="menu">
<a href="#">Dashboard</a>
<a href="#">Agents</a>
<a href="#">Workflows</a>
<a href="#">Analytics</a>
<a href="#">Alerts</a>
<a href="#">Settings</a>
</div>

</div>

<div class="main">

<div class="header">
<h1>AI Agent Monitoring</h1>
<div class="status">System Healthy</div>
</div>

<div class="cards">

<div class="card">
<h3>Active Agents</h3>
<p>24</p>
</div>

<div class="card">
<h3>Tasks Today</h3>
<p>1,842</p>
</div>

<div class="card">
<h3>Success Rate</h3>
<p>98%</p>
</div>

<div class="card">
<h3>Cost Saved</h3>
<p>$12K</p>
</div>

</div>

<div class="section">

<h2>Running Agents</h2>

<div class="agent">
<span>Customer Support Agent</span>
<span class="running">Running</span>
</div>

<div class="agent">
<span>Invoice Processing Agent</span>
<span class="running">Running</span>
</div>

<div class="agent">
<span>Sales Lead Agent</span>
<span class="warning">Warning</span>
</div>

<div class="agent">
<span>Report Generator Agent</span>
<span class="error">Error</span>
</div>

</div>

<div class="section">

<h2>Workflow Simulator</h2>

<textarea
id="workflow"
placeholder="Example: Analyze support tickets and generate weekly report..."
></textarea>

<button onclick="runWorkflow()">
Run AI Workflow
</button>

<div class="result" id="result"></div>

</div>

</div>

<script>

function runWorkflow(){

const workflow =
document.getElementById("workflow").value;

const result =
document.getElementById("result");

if(workflow.trim()===""){
alert("Enter workflow");
return;
}

result.style.display="block";

result.innerHTML=`

<b>Workflow Executed Successfully</b>

<br><br>

✓ Agent Assigned

<br>

✓ Data Processed

<br>

✓ Summary Generated

<br>

✓ Notification Sent

<br><br>

Estimated Time Saved:
<b>4.5 Hours</b>

<br><br>

Status:
<b style="color:#22c55e;">
Completed
</b>

`;

}

</script>

</body>
</html>
