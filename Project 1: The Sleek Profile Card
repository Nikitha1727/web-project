<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile Card</title>
    <style>
        /* Reset margins and set a background */
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #e0e5ec;
            height: 100vh;
            /* Flexbox centers the card beautifully */
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* The Card Container */
        .card {
            background-color: white;
            width: 300px;
            border-radius: 15px;
            padding: 30px 20px;
            text-align: center;
            /* A soft shadow for a modern 3D effect */
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }

        /* Hover effect makes the card "lift" up */
        .card:hover {
            transform: translateY(-10px);
        }

        /* Profile Picture Placeholder */
        .profile-pic {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #6e8efb, #a777e3);
            border-radius: 50%;
            margin: 0 auto 15px auto;
        }

        h2 {
            margin: 10px 0 5px 0;
            color: #333;
        }

        p {
            color: #777;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .btn {
            background-color: #6e8efb;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 25px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
        }

        .btn:hover {
            background-color: #a777e3;
        }
    </style>
</head>
<body>

    <div class="card">
        <div class="profile-pic"></div>
        <h2>Alex Developer</h2>
        <p>Front-End Enthusiast | HTML & CSS Ninja</p>
        <button class="btn">Message Me</button>
    </div>

</body>
</html>
