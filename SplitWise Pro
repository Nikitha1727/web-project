<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SplitWise Pro</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI,sans-serif;
}

body{
background:#f4f7fb;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
padding:20px;
}

.container{
width:100%;
max-width:850px;
background:white;
padding:30px;
border-radius:25px;
box-shadow:0 10px 30px rgba(0,0,0,.1);
}

h1{
text-align:center;
margin-bottom:25px;
color:#2563eb;
}

.input-group{
display:grid;
grid-template-columns:1fr 1fr 1fr auto;
gap:10px;
margin-bottom:20px;
}

input{
padding:14px;
border:2px solid #e5e7eb;
border-radius:10px;
outline:none;
}

button{
padding:14px 20px;
background:#2563eb;
border:none;
border-radius:10px;
color:white;
cursor:pointer;
}

button:hover{
background:#1d4ed8;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

th,td{
padding:15px;
text-align:left;
border-bottom:1px solid #ddd;
}

th{
background:#2563eb;
color:white;
}

.summary{
margin-top:25px;
padding:20px;
background:#eff6ff;
border-radius:15px;
}

.summary h2{
margin-bottom:15px;
}

.result{
font-size:20px;
font-weight:bold;
color:#16a34a;
margin-top:10px;
}

@media(max-width:700px){

.input-group{
grid-template-columns:1fr;
}

}

</style>
</head>

<body>

<div class="container">

<h1>💰 SplitWise Pro</h1>

<div class="input-group">

<input
type="text"
id="person"
placeholder="Person Name">

<input
type="text"
id="expense"
placeholder="Expense">

<input
type="number"
id="amount"
placeholder="Amount">

<button onclick="addExpense()">
Add
</button>

</div>

<table>

<thead>
<tr>
<th>Name</th>
<th>Expense</th>
<th>Amount</th>
</tr>
</thead>

<tbody id="expenseTable">

</tbody>

</table>

<div class="summary">

<h2>Expense Summary</h2>

<p>Total Expenses:
<span id="total">₹0</span>
</p>

<p>People Count:
<span id="people">0</span>
</p>

<div class="result" id="splitAmount">
Each Person Pays: ₹0
</div>

</div>

</div>

<script>

let expenses=[];
let peopleSet=new Set();

function addExpense(){

let person=
document.getElementById("person").value;

let expense=
document.getElementById("expense").value;

let amount=
Number(document.getElementById("amount").value);

if(!person || !expense || !amount){
alert("Fill all fields");
return;
}

expenses.push({
person,
expense,
amount
});

peopleSet.add(person);

renderTable();

document.getElementById("person").value="";
document.getElementById("expense").value="";
document.getElementById("amount").value="";

}

function renderTable(){

let table=
document.getElementById("expenseTable");

table.innerHTML="";

let total=0;

expenses.forEach(item=>{

total+=item.amount;

table.innerHTML+=`
<tr>
<td>${item.person}</td>
<td>${item.expense}</td>
<td>₹${item.amount}</td>
</tr>
`;

});

document.getElementById("total").innerText=
"₹"+total;

document.getElementById("people").innerText=
peopleSet.size;

let split=
peopleSet.size
? (total/peopleSet.size).toFixed(2)
:0;

document.getElementById("splitAmount").innerText=
"Each Person Pays: ₹"+split;

}

</script>

</body>
</html>
