<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Color Palette Generator</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#1f2937;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
min-height:100vh;
color:white;
}

h1{
margin-bottom:30px;
font-size:40px;
}

.palette{
display:flex;
gap:20px;
flex-wrap:wrap;
justify-content:center;
margin-bottom:30px;
}

.color-box{
width:170px;
height:250px;
border-radius:15px;
display:flex;
flex-direction:column;
justify-content:flex-end;
align-items:center;
padding:15px;
box-shadow:0 10px 20px rgba(0,0,0,.3);
transition:.3s;
}

.color-box:hover{
transform:scale(1.05);
}

.hex{
background:white;
color:black;
padding:8px 12px;
border-radius:8px;
font-weight:bold;
margin-bottom:10px;
}

button{
padding:10px 18px;
border:none;
border-radius:8px;
cursor:pointer;
background:#2563eb;
color:white;
font-size:15px;
}

button:hover{
background:#1d4ed8;
}

#generate{
margin-top:10px;
font-size:18px;
padding:14px 30px;
}

.toast{
position:fixed;
bottom:30px;
background:#16a34a;
padding:12px 20px;
border-radius:10px;
display:none;
}
</style>
</head>

<body>

<h1>🎨 Color Palette Generator</h1>

<div class="palette">

<div class="color-box">
<div class="hex">#000000</div>
<button onclick="copyColor(0)">Copy</button>
</div>

<div class="color-box">
<div class="hex">#000000</div>
<button onclick="copyColor(1)">Copy</button>
</div>

<div class="color-box">
<div class="hex">#000000</div>
<button onclick="copyColor(2)">Copy</button>
</div>

<div class="color-box">
<div class="hex">#000000</div>
<button onclick="copyColor(3)">Copy</button>
</div>

<div class="color-box">
<div class="hex">#000000</div>
<button onclick="copyColor(4)">Copy</button>
</div>

</div>

<button id="generate" onclick="generateColors()">
Generate Palette
</button>

<div class="toast" id="toast">
Copied!
</div>

<script>

const boxes=document.querySelectorAll(".color-box");
const hexes=document.querySelectorAll(".hex");

function randomColor(){

const letters="0123456789ABCDEF";

let color="#";

for(let i=0;i<6;i++){

color+=letters[Math.floor(Math.random()*16)];

}

return color;

}

function generateColors(){

boxes.forEach((box,index)=>{

const color=randomColor();

box.style.background=color;

hexes[index].innerText=color;

});

}

function copyColor(index){

navigator.clipboard.writeText(hexes[index].innerText);

const toast=document.getElementById("toast");

toast.style.display="block";

setTimeout(()=>{

toast.style.display="none";

},1500);

}

document.addEventListener("keydown",(e)=>{

if(e.code==="Space"){

e.preventDefault();

generateColors();

}

});

generateColors();

</script>

</body>
</html>
