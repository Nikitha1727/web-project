<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI Website Roaster</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body{
      background:#0f172a;
      color:white;
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:30px;
    }

    .container{
      width:100%;
      max-width:900px;
      background:#111827;
      border-radius:20px;
      padding:40px;
      box-shadow:0 0 25px rgba(0,0,0,0.4);
    }

    h1{
      font-size:42px;
      margin-bottom:10px;
      text-align:center;
    }

    .sub{
      text-align:center;
      color:#9ca3af;
      margin-bottom:30px;
    }

    .input-box{
      display:flex;
      gap:10px;
      margin-bottom:20px;
    }

    input{
      flex:1;
      padding:16px;
      border:none;
      border-radius:12px;
      background:#1f2937;
      color:white;
      font-size:16px;
      outline:none;
    }

    button{
      padding:16px 25px;
      border:none;
      border-radius:12px;
      background:#3b82f6;
      color:white;
      font-size:16px;
      cursor:pointer;
      transition:0.3s;
    }

    button:hover{
      background:#2563eb;
    }

    .mode-buttons{
      display:flex;
      gap:15px;
      margin-bottom:30px;
      justify-content:center;
    }

    .mode-btn{
      background:#1f2937;
    }

    .mode-btn.active{
      background:#10b981;
    }

    .result{
      background:#1e293b;
      border-radius:16px;
      padding:25px;
      display:none;
      animation:fadeIn 0.5s ease;
    }

    @keyframes fadeIn{
      from{
        opacity:0;
        transform:translateY(20px);
      }
      to{
        opacity:1;
        transform:translateY(0);
      }
    }

    .score-box{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
      gap:20px;
      margin-top:25px;
    }

    .card{
      background:#111827;
      padding:20px;
      border-radius:14px;
      text-align:center;
    }

    .card h3{
      margin-bottom:10px;
      color:#93c5fd;
    }

    .score{
      font-size:40px;
      font-weight:bold;
    }

    .roast-text{
      margin-top:25px;
      line-height:1.8;
      font-size:18px;
      color:#d1d5db;
    }

    .loading{
      text-align:center;
      margin-top:20px;
      display:none;
    }

    .footer{
      text-align:center;
      margin-top:30px;
      color:#6b7280;
      font-size:14px;
    }

    @media(max-width:700px){
      .input-box{
        flex-direction:column;
      }

      button{
        width:100%;
      }

      h1{
        font-size:32px;
      }
    }
  </style>
</head>

<body>

  <div class="container">

    <h1>🔥 AI Website Roaster</h1>

    <p class="sub">
      Enter any website URL and get roasted by AI 😂
    </p>

    <div class="mode-buttons">
      <button class="mode-btn active" onclick="setMode('roast')" id="roastBtn">
        Roast Mode
      </button>

      <button class="mode-btn" onclick="setMode('professional')" id="proBtn">
        Professional Audit
      </button>
    </div>

    <div class="input-box">
      <input type="text" id="websiteInput" placeholder="https://example.com">
      <button onclick="analyzeWebsite()">Analyze</button>
    </div>

    <div class="loading" id="loading">
      Analyzing Website...
    </div>

    <div class="result" id="result">

      <h2 id="websiteTitle"></h2>

      <div class="score-box">

        <div class="card">
          <h3>UI Design</h3>
          <div class="score" id="uiScore">0</div>
        </div>

        <div class="card">
          <h3>SEO</h3>
          <div class="score" id="seoScore">0</div>
        </div>

        <div class="card">
          <h3>Performance</h3>
          <div class="score" id="performanceScore">0</div>
        </div>

        <div class="card">
          <h3>Accessibility</h3>
          <div class="score" id="accessibilityScore">0</div>
        </div>

      </div>

      <div class="roast-text" id="roastText"></div>

    </div>

    <div class="footer">
      Built using HTML, CSS & JavaScript
    </div>

  </div>

  <script>

    let currentMode = "roast";

    function setMode(mode){

      currentMode = mode;

      document.getElementById("roastBtn").classList.remove("active");
      document.getElementById("proBtn").classList.remove("active");

      if(mode === "roast"){
        document.getElementById("roastBtn").classList.add("active");
      }
      else{
        document.getElementById("proBtn").classList.add("active");
      }
    }

    function randomScore(){
      return Math.floor(Math.random() * 40) + 60;
    }

    function analyzeWebsite(){

      const website = document.getElementById("websiteInput").value;

      if(website.trim() === ""){
        alert("Please enter website URL");
        return;
      }

      document.getElementById("loading").style.display = "block";
      document.getElementById("result").style.display = "none";

      setTimeout(() => {

        document.getElementById("loading").style.display = "none";
        document.getElementById("result").style.display = "block";

        const ui = randomScore();
        const seo = randomScore();
        const performance = randomScore();
        const access = randomScore();

        document.getElementById("websiteTitle").innerText =
          "Analysis Report for " + website;

        document.getElementById("uiScore").innerText = ui;
        document.getElementById("seoScore").innerText = seo;
        document.getElementById("performanceScore").innerText = performance;
        document.getElementById("accessibilityScore").innerText = access;

        let message = "";

        if(currentMode === "roast"){

          const roasts = [

            "This website loads slower than your motivation on Monday morning 😂",

            "The UI looks like it survived from 2012 and never recovered 💀",

            "SEO so weak even Google couldn't find it with a treasure map 😭",

            "The font choices feel like a crime against humanity.",

            "This design screams 'I discovered CSS yesterday.'",

            "Users open this site once and immediately close the tab emotionally."
          ];

          message = roasts[Math.floor(Math.random() * roasts.length)];

        }
        else{

          message =
          `
          Professional Audit Summary:

          • Website has decent structure but can improve spacing and typography.

          • SEO optimization needs better metadata and semantic HTML.

          • Accessibility can improve with higher contrast and ARIA labels.

          • Performance is acceptable but image optimization is recommended.

          • UI consistency and responsiveness require improvement for mobile users.
          `;
        }

        document.getElementById("roastText").innerText = message;

      }, 2000);

    }

  </script>

</body>
</html>
