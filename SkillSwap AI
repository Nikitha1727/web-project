<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SkillSwap AI</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:#0f172a;
color:white;
overflow-x:hidden;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:25px 8%;
position:sticky;
top:0;
background:rgba(15,23,42,0.95);
backdrop-filter:blur(10px);
z-index:100;
}

.logo{
font-size:32px;
font-weight:bold;
background:linear-gradient(90deg,#60a5fa,#c084fc);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

nav button{
padding:12px 22px;
border:none;
border-radius:12px;
background:#3b82f6;
color:white;
cursor:pointer;
}

/* HERO */

.hero{
min-height:90vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:40px;
}

.hero-content{
max-width:900px;
}

.hero h1{
font-size:5rem;
line-height:1.2;
margin-bottom:20px;
background:linear-gradient(
90deg,
#60a5fa,
#c084fc,
#f472b6
);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.hero p{
font-size:1.3rem;
color:#cbd5e1;
line-height:1.8;
margin-bottom:35px;
}

.hero-buttons{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.primary{
padding:15px 30px;
background:#3b82f6;
border:none;
border-radius:15px;
color:white;
font-size:1rem;
cursor:pointer;
}

.secondary{
padding:15px 30px;
background:transparent;
border:2px solid #64748b;
border-radius:15px;
color:white;
cursor:pointer;
}

/* FEATURES */

.section{
padding:80px 8%;
}

.section-title{
text-align:center;
font-size:3rem;
margin-bottom:60px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.card{
background:#1e293b;
padding:30px;
border-radius:25px;
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
}

.card h3{
margin-bottom:15px;
color:#93c5fd;
}

.card p{
line-height:1.8;
color:#cbd5e1;
}

/* SKILLS */

.skills{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:15px;
margin-top:30px;
}

.skill{
padding:12px 20px;
background:#1e293b;
border-radius:30px;
}

/* DEMO */

.demo{
background:#111827;
padding:60px;
border-radius:30px;
text-align:center;
}

.demo input{
width:100%;
max-width:500px;
padding:16px;
border:none;
border-radius:15px;
margin-bottom:20px;
font-size:16px;
}

.demo button{
padding:14px 25px;
background:#2563eb;
border:none;
border-radius:12px;
color:white;
cursor:pointer;
}

.output{
margin-top:25px;
padding:20px;
background:#1e293b;
border-radius:15px;
display:none;
line-height:1.8;
}

/* FOOTER */

footer{
padding:40px;
text-align:center;
color:#94a3b8;
}

/* MOBILE */

@media(max-width:768px){

.hero h1{
font-size:3rem;
}

.section-title{
font-size:2rem;
}

}

</style>
</head>
<body>

<nav>
<div class="logo">SkillSwap AI</div>
<button>Join Waitlist</button>
</nav>

<section class="hero">

<div class="hero-content">

<h1>
Your Knowledge Is Currency
</h1>

<p>
Teach what you know.
Learn what you don't.
Exchange skills with people around the world
without spending money.
</p>

<div class="hero-buttons">
<button class="primary">Start Learning</button>
<button class="secondary">Become a Mentor</button>
</div>

</div>

</section>

<section class="section">

<h2 class="section-title">
How It Works
</h2>

<div class="cards">

<div class="card">
<h3>🎓 Teach Skills</h3>
<p>
Share your expertise and earn Skill Credits.
</p>
</div>

<div class="card">
<h3>🪙 Earn Credits</h3>
<p>
Every teaching session rewards you with credits.
</p>
</div>

<div class="card">
<h3>🚀 Learn Anything</h3>
<p>
Spend credits to learn new skills from experts.
</p>
</div>

</div>

</section>

<section class="section">

<h2 class="section-title">
Popular Skills
</h2>

<div class="skills">

<div class="skill">HTML</div>
<div class="skill">CSS</div>
<div class="skill">JavaScript</div>
<div class="skill">Python</div>
<div class="skill">SQL</div>
<div class="skill">UI/UX</div>
<div class="skill">Public Speaking</div>
<div class="skill">Graphic Design</div>

</div>

</section>

<section class="section">

<div class="demo">

<h2 style="margin-bottom:20px;">
AI Skill Match Demo
</h2>

<input
id="skillInput"
placeholder="Enter a skill you want to learn..."
>

<br>

<button onclick="findMatch()">
Find Mentor
</button>

<div id="output" class="output"></div>

</div>

</section>

<footer>

© 2026 SkillSwap AI — Learn Together, Grow Together.

</footer>

<script>

function findMatch(){

const skill =
document.getElementById("skillInput").value;

const output =
document.getElementById("output");

if(skill.trim()===""){
alert("Enter a skill");
return;
}

output.style.display="block";

output.innerHTML=
`
<h3>🎯 Perfect Match Found</h3>

<p>
Mentor: Sarah Johnson
<br><br>

Expertise:
${skill}
<br><br>

Rating:
⭐ 4.9/5
<br><br>

Available:
Weekdays 6 PM - 9 PM
<br><br>

Cost:
15 Skill Credits
</p>
`;

}

</script>

</body>
</html>
