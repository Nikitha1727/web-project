body{
background:#f8fafc;
}

.hero{
background:linear-gradient(135deg,#2563eb,#06b6d4);
color:white;
padding:90px 0;
}

.hero h1{
font-size:55px;
font-weight:bold;
margin-bottom:20px;
}

.hero img{
box-shadow:0 15px 30px rgba(0,0,0,.3);
transition:.4s;
}

.hero img:hover{
transform:scale(1.05);
}

.feature-card{
transition:.3s;
border:none;
box-shadow:0 8px 20px rgba(0,0,0,.1);
margin-bottom:25px;
}

.feature-card:hover{
transform:translateY(-10px);
}

.pricing{
background:#eef2ff;
padding:70px 0;
}

.pricing .card{
border:none;
transition:.3s;
box-shadow:0 10px 20px rgba(0,0,0,.1);
}

.pricing .card:hover{
transform:scale(1.05);
}

.testimonial{
padding:70px 0;
}

footer{
background:#111827;
color:white;
padding:40px 0;
margin-top:40px;
}

footer h3{
margin-bottom:10px;
}

.btn{
border-radius:30px;
padding:12px 25px;
}

.navbar-brand{
font-size:28px;
}

.card{
border-radius:15px;
}

@media(max-width:768px){

.hero{
text-align:center;
}

.hero h1{
font-size:38px;
}

.hero img{
margin-top:30px;
}

}
