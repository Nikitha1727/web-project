<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dev Detective</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, Helvetica, sans-serif;
}

body{
  background:#020617;
  color:white;
  min-height:100vh;
  overflow-x:hidden;
}

/* BACKGROUND */

.bg{
  position:fixed;
  width:100%;
  height:100%;
  background:
  radial-gradient(circle at top left,#1e3a8a,transparent 30%),
  radial-gradient(circle at bottom right,#7e22ce,transparent 30%);
  z-index:-1;
}

/* CONTAINER */

.container{
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

/* TITLE */

.title{
  text-align:center;
  margin-bottom:40px;
}

.title h1{
  font-size:60px;
  margin-bottom:10px;
  background:linear-gradient(to right,#60a5fa,#c084fc,#22d3ee);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.title p{
  color:#cbd5e1;
  font-size:18px;
}

/* SEARCH */

.search-box{
  display:flex;
  justify-content:center;
  gap:15px;
  margin-bottom:50px;
}

.search-box input{
  width:400px;
  padding:16px;
  border:none;
  border-radius:14px;
  background:#111827;
  color:white;
  font-size:16px;
  outline:none;
}

.search-box button{
  padding:16px 28px;
  border:none;
  border-radius:14px;
  background:linear-gradient(to right,#2563eb,#9333ea);
  color:white;
  font-size:16px;
  cursor:pointer;
  transition:0.4s;
}

.search-box button:hover{
  transform:translateY(-3px);
}

/* PROFILE */

.profile{
  display:none;
  animation:fade 1s ease;
}

@keyframes fade{
  from{
    opacity:0;
    transform:translateY(20px);
  }
  to{
    opacity:1;
    transform:translateY(0);
  }
}

.top{
  display:flex;
  gap:30px;
  align-items:center;
  margin-bottom:40px;
  flex-wrap:wrap;
}

.avatar{
  width:180px;
  height:180px;
  border-radius:50%;
  border:5px solid #3b82f6;
  box-shadow:0 0 30px #3b82f6;
}

.user-info h2{
  font-size:42px;
  margin-bottom:10px;
}

.user-info p{
  color:#cbd5e1;
  line-height:1.7;
}

/* CARDS */

.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:40px;
}

.card{
  background:#111827;
  padding:25px;
  border-radius:20px;
  text-align:center;
  transition:0.4s;
  border:1px solid rgba(255,255,255,0.05);
}

.card:hover{
  transform:translateY(-8px);
  box-shadow:0 0 20px rgba(147,51,234,0.4);
}

.card h3{
  margin-bottom:15px;
  color:#93c5fd;
}

.card .number{
  font-size:40px;
  font-weight:bold;
}

/* ANALYSIS */

.analysis{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:25px;
}

.box{
  background:#111827;
  padding:25px;
  border-radius:20px;
}

.box h3{
  margin-bottom:15px;
  color:#60a5fa;
}

.box p{
  color:#d1d5db;
  line-height:1.8;
}

/* LANGUAGES */

.languages{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-top:15px;
}

.lang{
  padding:10px 16px;
  background:#1e293b;
  border-radius:30px;
  font-size:14px;
}

/* LOADING */

.loading{
  text-align:center;
  display:none;
  margin-top:30px;
  font-size:20px;
  color:#93c5fd;
}

/* MOBILE */

@media(max-width:768px){

  .title h1{
    font-size:42px;
  }

  .search-box{
    flex-direction:column;
    align-items:center;
  }

  .search-box input{
    width:100%;
  }

  .analysis{
    grid-template-columns:1fr;
  }

}

</style>
</head>

<body>

<div class="bg"></div>

<div class="container">

  <!-- TITLE -->

  <div class="title">
    <h1>Dev Detective</h1>
    <p>
      Analyze GitHub developers like an AI detective 🕵️
    </p>
  </div>

  <!-- SEARCH -->

  <div class="search-box">

    <input 
      type="text" 
      id="username" 
      placeholder="Enter GitHub Username"
    >

    <button onclick="fetchProfile()">
      Analyze Developer
    </button>

  </div>

  <!-- LOADING -->

  <div class="loading" id="loading">
    Scanning Developer Intelligence...
  </div>

  <!-- PROFILE -->

  <div class="profile" id="profile">

    <!-- TOP -->

    <div class="top">

      <img id="avatar" class="avatar">

      <div class="user-info">

        <h2 id="name"></h2>

        <p id="bio"></p>

      </div>

    </div>

    <!-- CARDS -->

    <div class="cards">

      <div class="card">
        <h3>Repositories</h3>
        <div class="number" id="repos"></div>
      </div>

      <div class="card">
        <h3>Followers</h3>
        <div class="number" id="followers"></div>
      </div>

      <div class="card">
        <h3>Following</h3>
        <div class="number" id="following"></div>
      </div>

      <div class="card">
        <h3>Developer Score</h3>
        <div class="number" id="score"></div>
      </div>

    </div>

    <!-- ANALYSIS -->

    <div class="analysis">

      <div class="box">

        <h3>AI Personality Analysis</h3>

        <p id="personality"></p>

      </div>

      <div class="box">

        <h3>Developer Roast Mode 🔥</h3>

        <p id="roast"></p>

      </div>

    </div>

    <!-- LANGUAGES -->

    <div class="box" style="margin-top:25px;">

      <h3>Top Technologies</h3>

      <div class="languages" id="languages"></div>

    </div>

  </div>

</div>

<script>

async function fetchProfile(){

  const username = document.getElementById("username").value;

  if(username === ""){
    alert("Please enter username");
    return;
  }

  document.getElementById("loading").style.display = "block";
  document.getElementById("profile").style.display = "none";

  try{

    const response = await fetch(
      `https://api.github.com/users/${username}`
    );

    const data = await response.json();

    document.getElementById("loading").style.display = "none";
    document.getElementById("profile").style.display = "block";

    document.getElementById("avatar").src = data.avatar_url;

    document.getElementById("name").innerText =
      data.name || data.login;

    document.getElementById("bio").innerText =
      data.bio || "No bio available.";

    document.getElementById("repos").innerText =
      data.public_repos;

    document.getElementById("followers").innerText =
      data.followers;

    document.getElementById("following").innerText =
      data.following;

    // RANDOM SCORE

    const score = Math.floor(Math.random() * 30) + 70;

    document.getElementById("score").innerText =
      score + "%";

    // PERSONALITY TYPES

    const personalities = [

      "🚀 Hackathon Warrior — ships projects faster than sleep disappears.",

      "🧠 Clean Code Architect — obsessed with elegant logic and structure.",

      "🔥 Midnight Debugger — probably fixes bugs at 3 AM.",

      "⚡ Full Stack Ninja — frontend, backend, chaos, everything.",

      "🌌 Open Source Explorer — loves experimenting with ideas.",

      "🎯 Consistency Machine — commits more regularly than most people workout."

    ];

    const roastLines = [

      "😂 Your unfinished side projects are forming their own ecosystem.",

      "🔥 GitHub says you're productive. Your sleep schedule disagrees.",

      "💀 You forked 42 repos and still haven't read the documentation.",

      "🚨 Too many private repos. What are you hiding?",

      "😭 Your commit graph looks healthier than most relationships."

    ];

    document.getElementById("personality").innerText =
      personalities[Math.floor(Math.random()*personalities.length)];

    document.getElementById("roast").innerText =
      roastLines[Math.floor(Math.random()*roastLines.length)];

    // LANGUAGES

    const langContainer =
      document.getElementById("languages");

    langContainer.innerHTML = "";

    const langs = [
      "JavaScript",
      "Python",
      "C++",
      "React",
      "Node.js",
      "HTML",
      "CSS"
    ];

    langs.forEach(lang => {

      const div = document.createElement("div");

      div.classList.add("lang");

      div.innerText = lang;

      langContainer.appendChild(div);

    });

  }

  catch(error){

    alert("User not found");

    document.getElementById("loading").style.display = "none";

  }

}

</script>

</body>
</html>
