<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MetroMind - Smart Metro Experience</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:#0f172a;
color:white;
min-height:100vh;
}

.navbar{
padding:20px 8%;
display:flex;
justify-content:space-between;
align-items:center;
background:#111827;
}

.logo{
font-size:32px;
font-weight:bold;
color:#38bdf8;
}

.hero{
text-align:center;
padding:80px 20px;
background:linear-gradient(135deg,#1e3a8a,#0f172a);
}

.hero h1{
font-size:65px;
margin-bottom:15px;
}

.hero p{
font-size:20px;
color:#cbd5e1;
max-width:700px;
margin:auto;
}

.dashboard{
padding:50px 8%;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.card{
background:#1e293b;
padding:25px;
border-radius:20px;
box-shadow:0 10px 20px rgba(0,0,0,0.2);
}

.card h2{
margin-bottom:15px;
color:#38bdf8;
}

.card p{
font-size:18px;
line-height:1.6;
}

.health{
font-size:50px;
font-weight:bold;
color:#22c55e;
text-align:center;
margin-top:15px;
}

.report-section{
padding:50px 8%;
}

.report-box{
background:#1e293b;
padding:30px;
border-radius:20px;
}

input, select{
width:100%;
padding:14px;
margin:10px 0;
border:none;
border-radius:10px;
background:#334155;
color:white;
}

button{
padding:14px;
width:100%;
background:#2563eb;
border:none;
border-radius:10px;
color:white;
cursor:pointer;
font-size:16px;
}

button:hover{
background:#1d4ed8;
}

.result{
margin-top:20px;
padding:20px;
background:#0f172a;
border-radius:12px;
display:none;
line-height:1.8;
}

.footer{
text-align:center;
padding:30px;
color:#94a3b8;
}

@media(max-width:768px){

.hero h1{
font-size:42px;
}

}

</style>
</head>
<body>

<div class="navbar">

<div class="logo">🚇 MetroMind</div>

<div>
Smart Metro Experience
</div>

</div>

<section class="hero">

<h1>MetroMind</h1>

<p>
Your Metro Knows The Route.
MetroMind Knows The Experience.
Helping commuters report issues, discover crowd levels,
and travel smarter.
</p>

</section>

<section class="dashboard">

<div class="card">

<h2>Majestic Station</h2>

<p>Crowd Level: High</p>
<p>Parking: Available</p>
<p>Escalator Status: Working</p>

<div class="health">
92
</div>

</div>

<div class="card">

<h2>Whitefield Station</h2>

<p>Crowd Level: Medium</p>
<p>Parking: Full</p>
<p>Escalator Status: Maintenance</p>

<div class="health" style="color:#f59e0b;">
76
</div>

</div>

<div class="card">

<h2>Peak Hours</h2>

<p>8:00 AM - 10:00 AM</p>
<p>6:00 PM - 8:30 PM</p>
<p>Recommended Travel:</p>
<p>11 AM - 4 PM</p>

</div>

</section>

<section class="report-section">

<div class="report-box">

<h2>📢 Report Metro Issue</h2>

<input
type="text"
id="station"
placeholder="Enter Station Name">

<select id="issue">

<option>Overcrowding</option>
<option>Escalator Not Working</option>
<option>Lift Issue</option>
<option>Water Leakage</option>
<option>Cleanliness Problem</option>

</select>

<button onclick="submitIssue()">
Submit Report
</button>

<div class="result" id="result"></div>

</div>

</section>

<div class="footer">

🚇 MetroMind • Making Public Transport Smarter

</div>

<script>

function submitIssue(){

const station =
document.getElementById("station").value;

const issue =
document.getElementById("issue").value;

if(station===""){
alert("Enter station name");
return;
}

document.getElementById("result").style.display="block";

document.getElementById("result").innerHTML =

`
✅ Report Submitted Successfully

<br><br>

📍 Station:
<b>${station}</b>

<br>

⚠️ Issue:
<b>${issue}</b>

<br><br>

Thank you for helping improve
the metro experience for everyone.

<br><br>

Community Impact Score:
+5 Points
`;

}

</script>

</body>
</html>
