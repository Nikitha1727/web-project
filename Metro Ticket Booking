<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Metro Ticket Booking</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body{
background:linear-gradient(135deg,#0d6efd,#6f42c1);
min-height:100vh;
}
.hero{padding:60px 0;color:#fff;text-align:center}
.card{border:none;border-radius:18px;box-shadow:0 10px 25px rgba(0,0,0,.2)}
.btn-book{background:#0d6efd;color:#fff}
.footer{color:#fff;text-align:center;padding:20px}
</style>
</head>
<body>

<div class="container hero">
<h1 class="display-4 fw-bold">Metro Ticket Booking</h1>
<p class="lead">Fast • Secure • Easy Travel</p>
</div>

<div class="container mb-5">
<div class="row justify-content-center">
<div class="col-lg-8">
<div class="card p-4">

<h3 class="mb-4">Book Your Ticket</h3>

<form>
<div class="row g-3">
<div class="col-md-6">
<label class="form-label">From Station</label>
<select class="form-select">
<option>Select Station</option>
<option>Ameerpet</option>
<option>Miyapur</option>
<option>LB Nagar</option>
<option>Raidurg</option>
<option>Nagole</option>
</select>
</div>

<div class="col-md-6">
<label class="form-label">To Station</label>
<select class="form-select">
<option>Select Station</option>
<option>Ameerpet</option>
<option>Miyapur</option>
<option>LB Nagar</option>
<option>Raidurg</option>
<option>Nagole</option>
</select>
</div>

<div class="col-md-6">
<label class="form-label">Journey Date</label>
<input type="date" class="form-control">
</div>

<div class="col-md-6">
<label class="form-label">Passengers</label>
<input type="number" min="1" value="1" class="form-control">
</div>

<div class="col-md-6">
<label class="form-label">Ticket Type</label>
<select class="form-select">
<option>One Way</option>
<option>Return</option>
<option>Day Pass</option>
</select>
</div>

<div class="col-md-6">
<label class="form-label">Payment Method</label>
<select class="form-select">
<option>UPI</option>
<option>Credit Card</option>
<option>Debit Card</option>
<option>Net Banking</option>
</select>
</div>

<div class="col-12">
<label class="form-label">Email</label>
<input type="email" class="form-control" placeholder="name@example.com">
</div>

<div class="col-12">
<button class="btn btn-book btn-lg w-100" type="button" onclick="book()">Book Ticket</button>
</div>
</div>
</form>

<hr>

<div class="row text-center">
<div class="col-md-4">
<h5>24/7 Booking</h5>
<p>Book anytime from anywhere.</p>
</div>
<div class="col-md-4">
<h5>Instant QR Ticket</h5>
<p>Receive digital ticket instantly.</p>
</div>
<div class="col-md-4">
<h5>Secure Payment</h5>
<p>Encrypted online transactions.</p>
</div>
</div>

</div>
</div>
</div>
</div>

<div class="footer">
© 2026 Metro Ticket Booking System
</div>

<script>
function book(){
alert("Ticket Booked Successfully!\nYour QR Ticket will be sent to your email.");
}
</script>

</body>
</html>
