<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Color Generator</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      transition: 0.5s;
      background: #222;
    }

    .container {
      background: white;
      padding: 30px;
      border-radius: 15px;
      text-align: center;
      width: 320px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    h1 {
      margin-bottom: 20px;
      color: #333;
    }

    .color-box {
      width: 100%;
      height: 150px;
      border-radius: 10px;
      margin-bottom: 20px;
      border: 2px solid #ddd;
      background: #3498db;
    }

    .color-code {
      font-size: 22px;
      font-weight: bold;
      margin-bottom: 20px;
      color: #444;
    }

    button {
      padding: 12px 20px;
      border: none;
      border-radius: 8px;
      background: #333;
      color: white;
      cursor: pointer;
      font-size: 16px;
      transition: 0.3s;
    }

    button:hover {
      background: #555;
    }

    .copied {
      margin-top: 15px;
      color: green;
      font-size: 14px;
    }
  </style>
</head>

<body>

  <div class="container">
    <h1>🎨 Color Generator</h1>

    <div class="color-box" id="colorBox"></div>

    <div class="color-code" id="colorCode">
      #3498DB
    </div>

    <button onclick="generateColor()">
      Generate Color
    </button>

    <br><br>

    <button onclick="copyColor()">
      Copy Code
    </button>

    <div class="copied" id="copiedMsg"></div>
  </div>

  <script>
    function generateColor() {

      let letters = "0123456789ABCDEF";
      let color = "#";

      for(let i = 0; i < 6; i++) {
        color += letters[Math.floor(Math.random() * 16)];
      }

      document.getElementById("colorBox").style.background = color;

      document.getElementById("colorCode").innerText = color;

      document.body.style.background = color;

      document.getElementById("copiedMsg").innerText = "";
    }

    function copyColor() {

      let color =
        document.getElementById("colorCode").innerText;

      navigator.clipboard.writeText(color);

      document.getElementById("copiedMsg").innerText =
        "✅ Color Code Copied!";
    }
  </script>

</body>
</html>
