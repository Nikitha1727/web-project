<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ReceiptIQ</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Inter,sans-serif;
}

body{
background:#0f172a;
color:white;
min-height:100vh;
padding:30px;
}

.container{
max-width:1200px;
margin:auto;
}

.header{
text-align:center;
margin-bottom:30px;
}

.header h1{
font-size:55px;
background:linear-gradient(
90deg,
#22c55e,
#06b6d4
);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.header p{
color:#cbd5e1;
margin-top:10px;
}

/* DASHBOARD */

.stats{
display:grid;
grid-template-columns:
repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:30px;
}

.card{
background:#1e293b;
padding:25px;
border-radius:20px;
}

.card h3{
color:#94a3b8;
margin-bottom:10px;
}

.card p{
font-size:32px;
font-weight:bold;
}

/* RECEIPT */

.receipt-box{
background:#1e293b;
padding:25px;
border-radius:20px;
margin-bottom:30px;
}

input{
width:100%;
padding:15px;
border:none;
border-radius:12px;
margin-top:10px;
}

button{
margin-top:15px;
padding:14px 25px;
border:none;
border-radius:12px;
background:#22c55e;
color:white;
cursor:pointer;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

th,td{
padding:15px;
text-align:left;
}

th{
background:#334155;
}

tr{
background:#1e293b;
border-bottom:1px solid #334155;
}

/* INSIGHT */

.insight{
background:#1e293b;
padding:25px;
border-radius:20px;
margin-top:25px;
line-height:1.8;
}

</style>
</head>
<body>

<div class="container">

<div class="header">

<h1>ReceiptIQ</h1>

<p>
Smart Expense Tracking & Budget Intelligence
</p>

</div>

<div class="stats">

<div class="card">
<h3>Total Spent</h3>
<p id="total">₹0</p>
</div>

<div class="card">
<h3>Transactions</h3>
<p id="count">0</p>
</div>

<div class="card">
<h3>Budget Left</h3>
<p id="budget">₹10000</p>
</div>

</div>

<div class="receipt-box">

<h2>Add Expense</h2>

<input
id="category"
placeholder="Category (Food, Travel, Shopping)"
>

<input
id="amount"
type="number"
placeholder="Amount"
>

<button onclick="addExpense()">
Add Expense
</button>

</div>

<table>

<thead>
<tr>
<th>Category</th>
<th>Amount</th>
</tr>
</thead>

<tbody id="expenses"></tbody>

</table>

<div class="insight" id="insight">

💡 AI Insight:
Your spending analysis will appear here.

</div>

</div>

<script>

let totalSpent = 0;
let transactions = 0;
const monthlyBudget = 10000;

function addExpense(){

const category =
document.getElementById("category").value;

const amount =
Number(document.getElementById("amount").value);

if(!category || !amount){

alert("Enter details");
return;

}

totalSpent += amount;
transactions++;

document.getElementById("total")
.innerText = "₹" + totalSpent;

document.getElementById("count")
.innerText = transactions;

document.getElementById("budget")
.innerText =
"₹" + (monthlyBudget-totalSpent);

document.getElementById("expenses")
.innerHTML +=

`
<tr>
<td>${category}</td>
<td>₹${amount}</td>
</tr>
`;

let insight = "";

if(totalSpent < 3000){

insight =
"✅ Spending is under control. You're managing your budget well.";

}
else if(totalSpent < 7000){

insight =
"⚠ Moderate spending detected. Monitor discretionary purchases.";

}
else{

insight =
"🚨 High spending alert. Consider reducing non-essential expenses.";

}

document.getElementById("insight")
.innerHTML =
`💡 AI Insight:<br><br>${insight}`;

}

</script>

</body>
</html>
