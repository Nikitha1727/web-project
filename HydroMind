<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HydroMind</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI,sans-serif;
}

body{
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#0ea5e9,#2563eb);
padding:20px;
}

.container{
background:white;
width:100%;
max-width:800px;
padding:35px;
border-radius:25px;
box-shadow:0 20px 40px rgba(0,0,0,.2);
text-align:center;
}

h1{
font-size:48px;
color:#0284c7;
margin-bottom:10px;
}

.subtitle{
color:#64748b;
margin-bottom:30px;
}

.water-circle{
width:220px;
height:220px;
margin:20px auto;
border-radius:50%;
border:10px solid #bae6fd;
position:relative;
overflow:hidden;
}

.water{
position:absolute;
bottom:0;
width:100%;
height:0%;
background:linear-gradient(#38bdf8,#0284c7);
transition:.5s;
}

.percent{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
font-size:36px;
font-weight:bold;
color:#0f172a;
z-index:10;
}

.buttons{
display:flex;
justify-content:center;
gap:15px;
margin-top:25px;
flex-wrap:wrap;
}

button{
padding:14px 24px;
border:none;
border-radius:12px;
cursor:pointer;
font-size:16px;
color:white;
}

.add{
background:#0284c7;
}

.reset{
background:#ef4444;
}

.stats{
margin-top:30px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:15px;
}

.card{
background:#f8fafc;
padding:20px;
border-radius:15px;
}

.card h3{
color:#64748b;
margin-bottom:10px;
}

.card p{
font-size:28px;
font-weight:bold;
color:#0f172a;
}

</style>
</head>
<body>

<div class="container">

<h1>💧 HydroMind</h1>

<p class="subtitle">
Track your hydration and stay healthy.
</p>

<div class="water-circle">

<div class="water" id="water"></div>

<div class="percent" id="percent">
0%
</div>

</div>

<div class="buttons">

<button class="add" onclick="addWater()">
+ 250ml
</button>

<button class="reset" onclick="resetWater()">
Reset
</button>

</div>

<div class="stats">

<div class="card">
<h3>Goal</h3>
<p>2L</p>
</div>

<div class="card">
<h3>Consumed</h3>
<p id="consumed">0ml</p>
</div>

<div class="card">
<h3>Streak</h3>
<p>12 Days</p>
</div>

</div>

</div>

<script>

let waterIntake = 0;
const goal = 2000;

function addWater(){

if(waterIntake < goal){
waterIntake += 250;
}

if(waterIntake > goal){
waterIntake = goal;
}

updateUI();

}

function resetWater(){

waterIntake = 0;
updateUI();

}

function updateUI(){

const percentage =
(waterIntake / goal) * 100;

document.getElementById("water")
.style.height =
percentage + "%";

document.getElementById("percent")
.innerText =
Math.round(percentage) + "%";

document.getElementById("consumed")
.innerText =
waterIntake + "ml";

}

</script>

</body>
</html>
