<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ocean of Knowledge</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    min-height:100vh;
    overflow:hidden;
    background:linear-gradient(
        to bottom,
        #87ceeb 0%,
        #4facfe 40%,
        #0077b6 100%
    );
}

/* Sky */

.sky{
    position:absolute;
    width:100%;
    height:50%;
}

.sun{
    width:120px;
    height:120px;
    border-radius:50%;
    background:#ffd60a;
    position:absolute;
    top:50px;
    right:80px;
    box-shadow:0 0 80px #ffd60a;
}

/* Ocean */

.ocean{
    position:absolute;
    bottom:0;
    width:100%;
    height:45%;
    background:#0077b6;
}

.wave{
    position:absolute;
    width:200%;
    height:100px;
    top:-50px;
    background:rgba(255,255,255,0.25);
    border-radius:50%;
    animation:wave 8s linear infinite;
}

.wave:nth-child(2){
    animation-duration:12s;
    opacity:.5;
}

@keyframes wave{
    from{
        transform:translateX(0);
    }
    to{
        transform:translateX(-50%);
    }
}

/* Title */

.title{
    position:absolute;
    top:60px;
    left:60px;
    color:white;
}

.title h1{
    font-size:70px;
}

.title p{
    font-size:20px;
    margin-top:10px;
}

/* Islands */

.island{
    position:absolute;
    width:180px;
    height:140px;
    background:#2d6a4f;
    border-radius:50%;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
    font-weight:bold;
    text-align:center;
    box-shadow:0 10px 25px rgba(0,0,0,.3);
}

.island::before{
    content:"";
    position:absolute;
    width:120px;
    height:70px;
    background:#52b788;
    border-radius:50%;
}

.island span{
    position:relative;
    z-index:2;
}

.html{
    left:10%;
    bottom:18%;
}

.css{
    left:35%;
    bottom:25%;
}

.js{
    left:60%;
    bottom:20%;
}

.react{
    left:80%;
    bottom:28%;
}

/* Cards */

.card{
    position:absolute;
    right:50px;
    top:180px;
    width:320px;
    background:rgba(255,255,255,.15);
    backdrop-filter:blur(15px);
    padding:25px;
    border-radius:20px;
    color:white;
}

.card h2{
    margin-bottom:15px;
}

.card p{
    line-height:1.8;
}

</style>
</head>
<body>

<div class="sky">
    <div class="sun"></div>
</div>

<div class="title">
    <h1>Ocean of Knowledge</h1>
    <p>Every skill you learn becomes a new island.</p>
</div>

<div class="card">
    <h2>Your Journey</h2>
    <p>
        Explore islands of knowledge and unlock
        new skills. Every completed skill expands
        your personal ocean.
    </p>
</div>

<div class="island html">
    <span>HTML Island</span>
</div>

<div class="island css">
    <span>CSS Island</span>
</div>

<div class="island js">
    <span>JavaScript Island</span>
</div>

<div class="island react">
    <span>React Island</span>
</div>

<div class="ocean">
    <div class="wave"></div>
    <div class="wave"></div>
</div>

</body>
</html>
