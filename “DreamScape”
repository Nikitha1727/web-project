<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DreamScape</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      height:100vh;
      overflow:hidden;
      background:linear-gradient(to bottom,#020111,#0f172a,#1e293b);
      color:white;
      position:relative;
    }

    /* STARS */

    .stars{
      position:absolute;
      width:100%;
      height:100%;
      overflow:hidden;
      z-index:0;
    }

    .stars span{
      position:absolute;
      width:3px;
      height:3px;
      background:white;
      border-radius:50%;
      animation:twinkle 3s infinite alternate;
    }

    @keyframes twinkle{
      from{
        opacity:0.2;
      }
      to{
        opacity:1;
      }
    }

    /* MAIN CONTENT */

    .container{
      position:relative;
      z-index:2;
      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      height:100vh;
      text-align:center;
      padding:20px;
    }

    h1{
      font-size:70px;
      margin-bottom:15px;
      background:linear-gradient(to right,#60a5fa,#c084fc,#f472b6);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .subtitle{
      color:#cbd5e1;
      font-size:20px;
      max-width:700px;
      margin-bottom:50px;
      line-height:1.7;
    }

    /* PLANETS */

    .universe{
      position:relative;
      width:700px;
      height:400px;
    }

    .planet{
      position:absolute;
      border-radius:50%;
      display:flex;
      justify-content:center;
      align-items:center;
      font-weight:bold;
      text-align:center;
      color:white;
      animation:float 4s ease-in-out infinite;
      cursor:pointer;
      transition:0.4s;
    }

    .planet:hover{
      transform:scale(1.1);
      box-shadow:0 0 40px rgba(255,255,255,0.7);
    }

    @keyframes float{
      0%{
        transform:translateY(0px);
      }
      50%{
        transform:translateY(-15px);
      }
      100%{
        transform:translateY(0px);
      }
    }

    .planet1{
      width:120px;
      height:120px;
      background:radial-gradient(circle,#3b82f6,#1e3a8a);
      top:40px;
      left:50px;
      box-shadow:0 0 30px #3b82f6;
    }

    .planet2{
      width:150px;
      height:150px;
      background:radial-gradient(circle,#f472b6,#831843);
      top:180px;
      left:250px;
      box-shadow:0 0 40px #f472b6;
      animation-delay:1s;
    }

    .planet3{
      width:100px;
      height:100px;
      background:radial-gradient(circle,#34d399,#064e3b);
      top:80px;
      right:80px;
      box-shadow:0 0 30px #34d399;
      animation-delay:2s;
    }

    .planet4{
      width:90px;
      height:90px;
      background:radial-gradient(circle,#facc15,#854d0e);
      bottom:20px;
      right:220px;
      box-shadow:0 0 25px #facc15;
      animation-delay:3s;
    }

    /* BUTTON */

    .btn{
      margin-top:40px;
      padding:15px 35px;
      border:none;
      border-radius:40px;
      background:linear-gradient(to right,#3b82f6,#9333ea);
      color:white;
      font-size:18px;
      cursor:pointer;
      transition:0.4s;
      box-shadow:0 0 25px rgba(147,51,234,0.5);
    }

    .btn:hover{
      transform:translateY(-5px) scale(1.05);
      box-shadow:0 0 40px rgba(147,51,234,0.8);
    }

    /* MOTIVATION */

    .quote{
      margin-top:30px;
      color:#e2e8f0;
      font-size:18px;
      opacity:0.9;
      animation:fade 4s infinite alternate;
    }

    @keyframes fade{
      from{
        opacity:0.4;
      }
      to{
        opacity:1;
      }
    }

    /* MOBILE */

    @media(max-width:768px){

      h1{
        font-size:50px;
      }

      .subtitle{
        font-size:16px;
      }

      .universe{
        width:100%;
        height:500px;
      }

      .planet1{
        left:20px;
      }

      .planet2{
        left:120px;
      }

      .planet3{
        right:20px;
      }

      .planet4{
        right:120px;
      }

    }

  </style>
</head>

<body>

  <!-- STARS -->

  <div class="stars">

    <span style="top:10%; left:20%;"></span>
    <span style="top:30%; left:70%;"></span>
    <span style="top:80%; left:40%;"></span>
    <span style="top:60%; left:90%;"></span>
    <span style="top:20%; left:50%;"></span>
    <span style="top:70%; left:15%;"></span>
    <span style="top:40%; left:35%;"></span>
    <span style="top:90%; left:75%;"></span>
    <span style="top:55%; left:60%;"></span>
    <span style="top:15%; left:85%;"></span>

  </div>

  <!-- MAIN -->

  <div class="container">

    <h1>DreamScape</h1>

    <p class="subtitle">
      Transform your dreams into glowing planets and build your own universe of goals, ambition, and future achievements.
    </p>

    <div class="universe">

      <div class="planet planet1">
        Career
      </div>

      <div class="planet planet2">
        Startup
      </div>

      <div class="planet planet3">
        Fitness
      </div>

      <div class="planet planet4">
        Travel
      </div>

    </div>

    <button class="btn">
      Enter Your Universe
    </button>

    <div class="quote">
      “Your future self is already proud of you.”
    </div>

  </div>

</body>
</html>
