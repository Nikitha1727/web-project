<!DOCTYPE html>
<html>
<head>
    <title>Typing Analyzer</title>
</head>
<body>

<h2>Typing Speed Test ⌨️</h2>

<p id="text">Coding is fun when you practice daily</p>

<textarea id="input" rows="4" cols="50" placeholder="Start typing..."></textarea>

<br><br>
<button onclick="check()">Check Result</button>

<p id="result"></p>

<script>
let startTime = new Date().getTime();

function check() {
    let endTime = new Date().getTime();
    let time = (endTime - startTime) / 1000;

    let original = document.getElementById("text").innerText;
    let typed = document.getElementById("input").value;

    let correct = 0;
    for (let i = 0; i < typed.length; i++) {
        if (typed[i] === original[i]) correct++;
    }

    let speed = (typed.length / 5) / (time / 60); // WPM
    let accuracy = (correct / original.length) * 100;

    document.getElementById("result").innerHTML =
        "Speed: " + speed.toFixed(2) + " WPM<br>Accuracy: " + accuracy.toFixed(2) + "%";
}
</script>

</body>
</html>
